#!/usr/bin/env bash
set -euo pipefail

# interpret — guest-side result interpretation via Claude Code
# Reads .lr-interpret request, invokes claude -p, posts to Linear via lr-update

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

CONFIG_FILE="${HOME}/.lr/config"
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

# Find lr-update
LR_UPDATE="${SCRIPT_DIR}/lr-update"
if [[ ! -x "$LR_UPDATE" ]]; then
  LR_UPDATE="lr-update"
fi

LR_RESULTS_MOUNT="${LR_RESULTS_MOUNT:-/mnt/lr-results}"

usage() {
  cat <<'EOF'
Usage: interpret <ISSUE_ID>

Reads a .lr-interpret request file from the results mount,
invokes Claude Code to interpret the results, and posts the
interpretation to Linear.

Options:
  -h, --help    Show this help

Environment:
  LR_RESULTS_MOUNT   Base path for results (default: /mnt/lr-results)
EOF
}

if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 ]]; then
  echo "ERROR: ISSUE_ID required" >&2
  usage
  exit 1
fi

ISSUE_ID="$1"
BASE="$LR_RESULTS_MOUNT/$ISSUE_ID"
REQUEST="$BASE/.lr-interpret"

if [[ ! -f "$REQUEST" ]]; then
  echo "ERROR: No interpretation request found at $REQUEST" >&2
  exit 1
fi

# Read request metadata
TIMESTAMP=$(jq -r .timestamp "$REQUEST")
COMMAND=$(jq -r .command "$REQUEST")
EXIT_CODE=$(jq -r .exit_code "$REQUEST")
DURATION=$(jq -r .duration "$REQUEST")
LOG_TAIL=$(jq -r .log_tail "$REQUEST")

RESULTS="$BASE/$TIMESTAMP"

if [[ ! -d "$RESULTS" ]]; then
  echo "ERROR: Results directory not found at $RESULTS" >&2
  exit 1
fi

# Assemble context
CONTEXT="CONTEXT:
- Issue: $ISSUE_ID
- Command: $COMMAND
- Exit code: $EXIT_CODE
- Duration: $DURATION
- Last 30 lines of output log:
$LOG_TAIL
- Result files:
$(ls -lhS "$RESULTS/" 2>/dev/null | tail -n +2 || echo "(none)")"

# Include small text file contents
for f in "$RESULTS"/*.csv "$RESULTS"/*.json "$RESULTS"/*.txt "$RESULTS"/*.tsv; do
  if [[ -f "$f" ]]; then
    fsize=$(wc -c < "$f")
    if (( fsize < 50000 )); then
      CONTEXT="$CONTEXT

- Contents of $(basename "$f"):
$(cat "$f")"
    fi
  fi
done 2>/dev/null

# Include custom prompt if available
if [[ -f "$RESULTS/.lr-agent-prompt" ]]; then
  CONTEXT="$CONTEXT

- Custom instructions (.lr-agent-prompt):
$(cat "$RESULTS/.lr-agent-prompt")"
fi

# Invoke Claude Code in print mode
SYSTEM_PROMPT="You are a research assistant interpreting neuroscience analysis results. Write a concise update for a Linear issue. Include: (1) what completed, (2) key quantitative results, (3) notable observations, (4) suggested next steps. Use markdown. Be specific, not vague."

echo "Interpreting results for $ISSUE_ID..."

INTERPRETATION=$(claude -p --system-prompt "$SYSTEM_PROMPT" "$CONTEXT")

if [[ -z "$INTERPRETATION" ]]; then
  echo "ERROR: Claude returned empty interpretation" >&2
  exit 1
fi

# Post to Linear
"$LR_UPDATE" comment "$ISSUE_ID" "**Agent Interpretation**

$INTERPRETATION"

"$LR_UPDATE" status "$ISSUE_ID" "Ready for Review"

# Clean up request file
rm "$REQUEST"

echo "Interpretation posted to $ISSUE_ID"
